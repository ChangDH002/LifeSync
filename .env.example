MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=dementia_app
SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Social login (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
SOCIAL_STATE_SECRET=replace-with-a-long-random-secret
SOCIAL_REDIRECT_ALLOWLIST=http://localhost:3000,http://127.0.0.1:3000

# Gemini AI (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SBERT / 데이터셋
SBERT_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SBERT_DATASET_PATH=app/data/dementia_question_dataset_7000.csv
