APP_ENV=production
APP_NAME=LifeSync Backend API

MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
DATABASE_NAME=lifesync_prod

CORS_ORIGINS=https://<your-frontend-domain>
SOCIAL_REDIRECT_ALLOWLIST=https://<your-frontend-domain>

SECRET_KEY=<long-random-secret>
JWT_SECRET_KEY=<long-random-secret>
SOCIAL_STATE_SECRET=<long-random-secret>

ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=14

AI_CHATBOT_URL=https://<your-ai-domain>

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
